<Window x:Class="AshenTasker.Views.Dialogs.BlackoutOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Blackout Overlay"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Black" Width="328">
    <Canvas x:Name="BlackoutCanvas"
            Background="Black">
        <StackPanel x:Name="InstructionPanel"
                    Opacity="0.78">
            <TextBlock Text="Blackout overlay"
                       FontFamily="Segoe UI"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#5A5A5A"
                       HorizontalAlignment="Center" />
            <StackPanel Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                <TextBlock Text="Press"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI"
                           FontSize="14"
                           Foreground="#4A4A4A" />
                <Border Margin="7,0"
                        Padding="8,2"
                        CornerRadius="4"
                        Background="#08000000"
                        BorderBrush="#3F5C5C5C"
                        BorderThickness="1">
                    <TextBlock Text="Ctrl"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Foreground="#626262" />
                </Border>
                <Border Margin="0,0,7,0"
                        Padding="8,2"
                        CornerRadius="4"
                        Background="#08000000"
                        BorderBrush="#3F5C5C5C"
                        BorderThickness="1">
                    <TextBlock Text="B"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Foreground="#626262" />
                </Border>
                <TextBlock Text="to close"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI"
                           FontSize="14"
                           Foreground="#4A4A4A" />
            </StackPanel>
            <StackPanel Margin="0,7,0,0"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                <TextBlock Text="Use"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI"
                           FontSize="14"
                           Foreground="#424242" />
                <Border Margin="7,0"
                        Padding="8,2"
                        CornerRadius="4"
                        Background="#08000000"
                        BorderBrush="#365C5C5C"
                        BorderThickness="1">
                    <TextBlock Text="Left Arrow"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Foreground="#5A5A5A" />
                </Border>
                <TextBlock Text="or"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI"
                           FontSize="14"
                           Foreground="#424242" />
                <Border Margin="7,0"
                        Padding="8,2"
                        CornerRadius="4"
                        Background="#08000000"
                        BorderBrush="#365C5C5C"
                        BorderThickness="1">
                    <TextBlock Text="Right Arrow"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Foreground="#5A5A5A" />
                </Border>
                <TextBlock Text="to change screens"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI"
                           FontSize="14"
                           Foreground="#424242" />
            </StackPanel>
        </StackPanel>
    </Canvas>
</Window>
