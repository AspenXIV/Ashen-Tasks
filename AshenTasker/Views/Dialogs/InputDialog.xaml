<Window x:Class="AshenTasker.Views.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Input"
        Width="420"
        Height="190"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#1D1D1D">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="DialogTitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#DDDDDD" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="8"
            Background="#171717"
            BorderBrush="#44606060"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Background="#5A111111"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="DialogTitleText"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#F2F2F2"
                           Text="Input" />

                <Button Grid.Column="1"
                        Style="{StaticResource DialogTitleBarButtonStyle}"
                        Click="CloseButton_OnClick"
                        Content="&#xE8BB;"
                        Foreground="#E5E5E5" />
            </Grid>

            <Grid Grid.Row="1" Margin="16,12,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="PromptText"
                           Foreground="#EEEEEE"
                           FontSize="13"
                           TextWrapping="Wrap" />

                <TextBox x:Name="ValueTextBox"
                         Grid.Row="1"
                         Height="32"
                         Margin="0,12,0,0"
                         VerticalContentAlignment="Center" />

                <StackPanel Grid.Row="2"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <Button Width="78"
                            Height="30"
                            Margin="0,0,8,0"
                            HorizontalContentAlignment="Center"
                            Click="CancelButton_OnClick"
                            Content="Cancel" />
                    <Button Width="78"
                            Height="30"
                            HorizontalContentAlignment="Center"
                            Click="OkButton_OnClick"
                            Content="OK" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
