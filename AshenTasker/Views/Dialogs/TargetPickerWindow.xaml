<Window x:Class="AshenTasker.Views.Dialogs.TargetPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Select Target Window"
        Width="920"
        Height="580"
        MinWidth="760"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#141414">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="DialogTitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#DDDDDD" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="HeaderCellStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#AABDBDBD" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="8"
            Background="#CC202020"
            BorderBrush="#44606060"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="42" />
            </Grid.RowDefinitions>

            <Grid Background="#5A111111"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Border Width="22"
                            Height="22"
                            CornerRadius="6"
                            Background="#26313131"
                            BorderBrush="#557A7A7A"
                            BorderThickness="1">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#C8C8C8"
                                   Text="T" />
                    </Border>
                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#F2F2F2"
                               Text="Select Target Window" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Top"
                            Orientation="Horizontal">
                    <Button Style="{StaticResource DialogTitleBarButtonStyle}"
                            Click="MinimizeButton_OnClick"
                            Content="&#xE921;" />
                    <Button Style="{StaticResource DialogTitleBarButtonStyle}"
                            Click="CloseButton_OnClick"
                            Content="&#xE8BB;"
                            Foreground="#E5E5E5" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Background="#66383838">
                <TextBlock Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#F2F2F2"
                           Text="TARGET PROCESSES" />
                <Button Width="88"
                        Height="28"
                        Margin="0,0,12,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="RefreshButton_OnClick"
                        Content="Refresh" />
            </Grid>

            <Grid Grid.Row="2" Margin="12,8,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="240" />
                </Grid.ColumnDefinitions>

                <Border Background="#35242424"
                        BorderBrush="#405F5F5F"
                        BorderThickness="1"
                        CornerRadius="6">
                    <ScrollViewer x:Name="TargetTableScrollViewer"
                                  VerticalScrollBarVisibility="Visible"
                                  HorizontalScrollBarVisibility="Visible"
                                  CanContentScroll="False"
                                  Padding="0,0,10,10">
                        <Grid MinWidth="780">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Background="#3A282828">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition x:Name="HeaderNameColumn" Width="220" MinWidth="130" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition x:Name="HeaderPidColumn" Width="76" MinWidth="56" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition x:Name="HeaderCpuColumn" Width="80" MinWidth="58" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition x:Name="HeaderIoColumn" Width="120" MinWidth="82" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition x:Name="HeaderPrivateBytesColumn" Width="110" MinWidth="92" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Margin="4,0" Style="{StaticResource HeaderCellStyle}" Text="Name" />
                                <GridSplitter Grid.Column="2" Width="4" HorizontalAlignment="Stretch" Background="#205A5A5A" DragDelta="ColumnSplitter_OnDragDelta" DragCompleted="ColumnSplitter_OnDragCompleted" />
                                <TextBlock Grid.Column="3" Margin="4,0" HorizontalAlignment="Right" Style="{StaticResource HeaderCellStyle}" Text="PID" />
                                <GridSplitter Grid.Column="4" Width="4" HorizontalAlignment="Stretch" Background="#205A5A5A" DragDelta="ColumnSplitter_OnDragDelta" DragCompleted="ColumnSplitter_OnDragCompleted" />
                                <TextBlock Grid.Column="5" Margin="4,0" HorizontalAlignment="Right" Style="{StaticResource HeaderCellStyle}" Text="CPU" />
                                <GridSplitter Grid.Column="6" Width="4" HorizontalAlignment="Stretch" Background="#205A5A5A" DragDelta="ColumnSplitter_OnDragDelta" DragCompleted="ColumnSplitter_OnDragCompleted" />
                                <TextBlock Grid.Column="7" Margin="4,0" HorizontalAlignment="Right" Style="{StaticResource HeaderCellStyle}" Text="I/O Rate" />
                                <GridSplitter Grid.Column="8" Width="4" HorizontalAlignment="Stretch" Background="#205A5A5A" DragDelta="ColumnSplitter_OnDragDelta" DragCompleted="ColumnSplitter_OnDragCompleted" />
                                <TextBlock Grid.Column="9" Margin="4,0" HorizontalAlignment="Right" Style="{StaticResource HeaderCellStyle}" Text="Private Bytes" />
                            </Grid>

                            <TreeView x:Name="TargetTreeView"
                                      Grid.Row="1"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Foreground="#F2F2F2"
                                      Padding="0"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      SelectedItemChanged="TargetTreeView_OnSelectedItemChanged" />
                        </Grid>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="1"
                        Margin="12,0,0,0"
                        Padding="12"
                        CornerRadius="8"
                        Background="#552A2A2A"
                        BorderBrush="#405F5F5F"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Foreground="#B8D0D0D0" Text="Process" />
                        <TextBlock x:Name="ProcessText"
                                   Margin="0,4,0,12"
                                   Foreground="#F2F2F2"
                                   Text="-" />
                        <TextBlock Foreground="#B8D0D0D0" Text="Window" />
                        <TextBlock x:Name="WindowText"
                                   Margin="0,4,0,12"
                                   Foreground="#F2F2F2"
                                   Text="-"
                                   TextWrapping="Wrap" />
                        <TextBlock Foreground="#B8D0D0D0" Text="PID" />
                        <TextBlock x:Name="PidText"
                                   Margin="0,4,0,12"
                                   Foreground="#F2F2F2"
                                   Text="-" />
                        <TextBlock Foreground="#B8D0D0D0" Text="Bounds" />
                        <TextBlock x:Name="BoundsText"
                                   Margin="0,4,0,0"
                                   Foreground="#F2F2F2"
                                   Text="-" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="3"
                        Margin="12,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Width="86"
                        Height="28"
                        Margin="0,0,8,0"
                        Click="CancelButton_OnClick"
                        Content="Cancel" />
                <Button x:Name="LinkButton"
                        Width="86"
                        Height="28"
                        Click="LinkButton_OnClick"
                        Content="Attach" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
