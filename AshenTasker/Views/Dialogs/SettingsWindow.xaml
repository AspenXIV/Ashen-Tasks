<Window x:Class="AshenTasker.Views.Dialogs.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Ashen Tasker - Info And Settings"
        Width="780"
        Height="520"
        MinWidth="640"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#141414">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="DialogTitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#DDDDDD" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AABDBDBD" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="SettingsTabStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabChrome"
                                Background="Transparent">
                            <Grid>
                                <Border x:Name="SelectionRail"
                                        Width="3"
                                        HorizontalAlignment="Left"
                                        Background="#4FA3FF"
                                        Visibility="Collapsed" />
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="#202A2A2A" />
                                <Setter TargetName="SelectionRail" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="#182A2A2A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="8"
            Background="#171717"
            BorderBrush="#44606060"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Background="#5A111111"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Border Width="22"
                            Height="22"
                            CornerRadius="6"
                            Background="#26313131"
                            BorderBrush="#557A7A7A"
                            BorderThickness="1">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#C8C8C8"
                                   Text="i" />
                    </Border>
                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#F2F2F2"
                               Text="Info And Settings" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Top"
                            Orientation="Horizontal">
                    <Button Style="{StaticResource DialogTitleBarButtonStyle}"
                            Click="MinimizeButton_OnClick"
                            Content="&#xE921;" />
                    <Button Style="{StaticResource DialogTitleBarButtonStyle}"
                            Click="CloseButton_OnClick"
                            Content="&#xE8BB;"
                            Foreground="#E5E5E5" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="178" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,18,0,0">
                    <TextBlock Margin="0,0,0,12"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#AABDBDBD"
                               Text="PAGES" />
                    <RadioButton x:Name="InfoTabButton"
                                 Style="{StaticResource SettingsTabStyle}"
                                 GroupName="SettingsPages"
                                 IsChecked="True"
                                 Checked="SettingsTab_OnChecked"
                                 Content="Info" />
                    <RadioButton x:Name="SettingsTabButton"
                                 Style="{StaticResource SettingsTabStyle}"
                                 GroupName="SettingsPages"
                                 Checked="SettingsTab_OnChecked"
                                 Content="Settings" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#40484848" />

                <Grid Grid.Column="2"
                      Margin="22,18,22,20">
                    <ScrollViewer x:Name="InfoPage"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,18,0"
                                    HorizontalAlignment="Stretch">
                            <Border Width="170"
                                    Height="170"
                                    HorizontalAlignment="Center"
                                    CornerRadius="8"
                                    Background="#222A2A2A"
                                    BorderBrush="#557A7A7A"
                                    BorderThickness="1">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#C8C8C8"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                       Text="Ashen Mark" />
                            </Border>

                            <TextBlock Margin="0,22,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="#F2F2F2"
                                       TextAlignment="Center"
                                       Text="Ashen Tasker" />
                            <TextBlock Margin="0,4,0,26"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource MutedTextStyle}"
                                       TextAlignment="Center"
                                       Text="by AspenXIV" />

                            <TextBlock HorizontalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#F2F2F2"
                                       TextAlignment="Center"
                                       Text="Credits" />
                            <RichTextBox Margin="0,10,0,0"
                                         Padding="0"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="#DDDDDD">
                                <FlowDocument FontFamily="Segoe UI"
                                              FontSize="13"
                                              PagePadding="0"
                                              TextAlignment="Center">
                                    <Paragraph Margin="0,0,0,8" TextAlignment="Center">
                                        <Bold>WPF-UI</Bold>
                                        <Run Text=" - Windows 11 Fluent controls and styling." />
                                    </Paragraph>
                                    <Paragraph Margin="0,0,0,8" TextAlignment="Center">
                                        <Bold>.NET / WPF</Bold>
                                        <Run Text=" - Desktop application framework." />
                                    </Paragraph>
                                    <Paragraph Margin="0" TextAlignment="Center">
                                        <Run Text="More credits will be added here as the project grows." />
                                    </Paragraph>
                                </FlowDocument>
                            </RichTextBox>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="SettingsPage"
                                  Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#F2F2F2"
                                       Text="Macro Library" />
                            <TextBlock Margin="0,14,0,5"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="Macro Directory" />
                            <Grid Margin="0,0,0,26">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="104" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="MacroDirectoryTextBox"
                                         Height="34"
                                         FontSize="13"
                                         VerticalContentAlignment="Center"
                                         IsReadOnly="True"
                                         TextWrapping="NoWrap" />
                                <Button Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource SettingsButtonStyle}"
                                        Click="BrowseMacroDirectoryButton_OnClick"
                                        Content="Browse" />
                            </Grid>

                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#F2F2F2"
                                       Text="Overlay" />
                            <TextBlock Margin="0,14,0,5"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="Toggle Overlay Hotkey" />
                            <Button x:Name="ToggleOverlayHotkeyButton"
                                    Height="34"
                                    Margin="0,0,0,14"
                                    HorizontalContentAlignment="Left"
                                    Padding="12,0"
                                    Style="{StaticResource SettingsButtonStyle}"
                                    Click="HotkeyCaptureButton_OnClick"
                                    Content="F9" />
                            <CheckBox x:Name="PauseWhenTargetChangesCheckBox"
                                      Margin="0,0,0,26"
                                      Foreground="#F2F2F2"
                                      Checked="PauseWhenTargetChangesCheckBox_OnChanged"
                                      Unchecked="PauseWhenTargetChangesCheckBox_OnChanged"
                                      Content="Pause when target changes" />

                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#F2F2F2"
                                       Text="Hotkeys" />
                            <Grid Margin="0,14,0,26">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="Record" />
                                <Button x:Name="RecordHotkeyButton"
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Height="34"
                                        HorizontalContentAlignment="Left"
                                        Padding="12,0"
                                        Style="{StaticResource SettingsButtonStyle}"
                                        Click="HotkeyCaptureButton_OnClick"
                                        Content="Ctrl+R" />
                                <TextBlock Grid.Row="2"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="Play" />
                                <Button x:Name="PlayHotkeyButton"
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Height="34"
                                        HorizontalContentAlignment="Left"
                                        Padding="12,0"
                                        Style="{StaticResource SettingsButtonStyle}"
                                        Click="HotkeyCaptureButton_OnClick"
                                        Content="Ctrl+P" />
                                <TextBlock Grid.Row="4"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="Stop" />
                                <Button x:Name="StopHotkeyButton"
                                        Grid.Row="4"
                                        Grid.Column="1"
                                        Height="34"
                                        HorizontalContentAlignment="Left"
                                        Padding="12,0"
                                        Style="{StaticResource SettingsButtonStyle}"
                                        Click="HotkeyCaptureButton_OnClick"
                                        Content="Ctrl+S" />
                            </Grid>

                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#F2F2F2"
                                       Text="Privacy" />
                            <CheckBox x:Name="HideProcessIdsCheckBox"
                                      Margin="0,14,0,26"
                                      Foreground="#F2F2F2"
                                      Checked="HideProcessIdsCheckBox_OnChanged"
                                      Unchecked="HideProcessIdsCheckBox_OnChanged"
                                      Content="Hide process IDs in target picker" />

                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#F2F2F2"
                                       Text="Interface" />
                            <TextBlock Margin="0,14,0,5"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="Theme" />
                            <ComboBox Height="34" SelectedIndex="0">
                                <ComboBoxItem Content="Monochrome Dark" />
                            </ComboBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
