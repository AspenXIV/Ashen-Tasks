<ui:FluentWindow x:Class="AshenTasker.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="Ashen Tasker"
                 Width="1500"
                 Height="840"
                 MinWidth="1180"
                 MinHeight="700"
                 Icon="Assets/Icons/Ashen Tasker Icon.ico"
                 WindowBackdropType="Acrylic"
                 ExtendsContentIntoTitleBar="True"
                 WindowStartupLocation="CenterScreen">
    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F0141414" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#EC1A1A1A" />
        <SolidColorBrush x:Key="PanelBrush" Color="#B82A2A2A" />
        <SolidColorBrush x:Key="PanelHeaderBrush" Color="#66363636" />
        <SolidColorBrush x:Key="PanelStrokeBrush" Color="#3FFFFFFF" />
        <SolidColorBrush x:Key="PanelStrokeStrongBrush" Color="#587A7A7A" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#B8D0D0D0" />
        <SolidColorBrush x:Key="BlueAccentBrush" Color="#C8C8C8" />
        <SolidColorBrush x:Key="GreenAccentBrush" Color="#BEBEBE" />
        <SolidColorBrush x:Key="RedAccentBrush" Color="#D8D8D8" />
        <SolidColorBrush x:Key="ButtonBrush" Color="#B0252525" />
        <SolidColorBrush x:Key="ButtonDisabledBrush" Color="#73343434" />
        <SolidColorBrush x:Key="HotkeyBrush" Color="#E7131313" />

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      Direction="270"
                                      Opacity="0.24"
                                      ShadowDepth="3"
                                      Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#EEEEEE" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        </Style>

        <Style x:Key="CompactInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#DDDDDD" />
            <Setter Property="Background" Value="#53242424" />
            <Setter Property="BorderBrush" Value="#334F4F4F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ThinButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="Background" Value="{StaticResource ButtonBrush}" />
            <Setter Property="BorderBrush" Value="#4E777777" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ThinButtonStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="12,0,62,0" />
        </Style>

        <Style x:Key="TinyFileButtonStyle" TargetType="Button" BasedOn="{StaticResource ThinButtonStyle}">
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#56242424" />
            <Setter Property="BorderBrush" Value="#44606060" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#70313131" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkspaceTabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="29" />
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#D6D6D6" />
            <Setter Property="Background" Value="#4A242424" />
            <Setter Property="BorderBrush" Value="#40525252" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8,8,0,0">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="#60323232" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkspaceTabActiveButtonStyle" TargetType="Button" BasedOn="{StaticResource WorkspaceTabButtonStyle}">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#95323232" />
            <Setter Property="BorderBrush" Value="#7A5F5F5F" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="RailModeTabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Background" Value="#2A202020" />
            <Setter Property="BorderBrush" Value="#284F4F4F" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="#42303030" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RailModeTabActiveButtonStyle" TargetType="Button" BasedOn="{StaticResource RailModeTabButtonStyle}">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#60303030" />
            <Setter Property="BorderBrush" Value="#6A646464" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="AutoclickerGroupStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0,8,0,0" />
            <Setter Property="BorderBrush" Value="#324F4F4F" />
            <Setter Property="BorderThickness" Value="1,1,0,0" />
        </Style>

        <Style x:Key="AutoclickerRadioStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="22" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="AutoclickerAdvancedExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="#E6E6E6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderSite"
                                          Height="26"
                                          Padding="8,0"
                                          HorizontalContentAlignment="Stretch"
                                          Background="#56242424"
                                          BorderBrush="#44606060"
                                          BorderThickness="1"
                                          Foreground="#E6E6E6"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <DockPanel LastChildFill="True">
                                    <TextBlock x:Name="Arrow"
                                               DockPanel.Dock="Right"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="9"
                                               Text="&#xE70D;" />
                                    <ContentPresenter VerticalAlignment="Center"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True" />
                                </DockPanel>
                            </ToggleButton>
                            <Border x:Name="ExpandSite"
                                    Padding="8"
                                    Background="#2F202020"
                                    BorderBrush="#324F4F4F"
                                    BorderThickness="1,0,1,1"
                                    Visibility="Collapsed">
                                <ContentPresenter />
                            </Border>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Arrow" Property="Text" Value="&#xE70E;" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconToolButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Background" Value="#70242424" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.78" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.56" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryPlayButtonStyle" TargetType="Button" BasedOn="{StaticResource IconToolButtonStyle}">
            <Setter Property="Width" Value="82" />
            <Setter Property="Background" Value="#8C5A3FE0" />
        </Style>

        <Style x:Key="SmallActionButtonStyle" TargetType="Button" BasedOn="{StaticResource IconToolButtonStyle}">
            <Setter Property="Width" Value="32" />
        </Style>

        <Style x:Key="TopMenuStyle" TargetType="Menu">
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="12,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="HotkeyBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="3,0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="Background" Value="{StaticResource HotkeyBrush}" />
            <Setter Property="BorderBrush" Value="#557A7A7A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="TitleBarComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Width" Value="150" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="12,0,0,0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="Background" Value="#56242424" />
            <Setter Property="BorderBrush" Value="#44606060" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Foreground" Value="#DDDDDD" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="TitleBarIconButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="{StaticResource BlueAccentBrush}" />
        </Style>
    </ui:FluentWindow.Resources>

    <Border Margin="0"
            CornerRadius="10"
            Background="Transparent"
            BorderBrush="#53686868"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="*" />
                <RowDefinition Height="20" />
            </Grid.RowDefinitions>

            <CheckBox x:Name="CenterAcrylicToggle"
                      IsChecked="True"
                      Visibility="Collapsed"
                      Checked="CenterAcrylicToggle_OnChanged"
                      Unchecked="CenterAcrylicToggle_OnChanged" />

            <Grid Grid.Row="0"
                  Background="#5A111111"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="12,0,0,0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Width="20"
                            Height="20"
                            CornerRadius="6"
                            Background="#252D2D2D"
                            BorderBrush="#667A7A7A"
                            BorderThickness="1">
                        <Grid>
                            <Path Width="11"
                                  Height="13"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M 5.5 0 L 11 13 L 8.7 13 L 7.7 10.2 L 3.3 10.2 L 2.3 13 L 0 13 Z M 4.1 8.1 L 6.9 8.1 L 5.5 4.2 Z"
                                  Fill="#E2E2E2"
                                  Stretch="Fill" />
                            <Border Width="7"
                                    Height="1"
                                    Margin="0,1,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="#FF9B9B9B" />
                        </Grid>
                    </Border>
                    <TextBlock Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#F3F3F3"
                               Text="Ashen Tasker" />
                    <Button x:Name="ToolsMenuButton"
                            Margin="12,0,0,0"
                            Style="{StaticResource TitleBarIconButtonStyle}"
                            Click="ToolsMenuButton_OnClick"
                            Content="&#xE9D2;"
                            FontFamily="Segoe MDL2 Assets">
                        <Button.ToolTip>
                            <TextBlock FontFamily="Segoe UI" Text="Tools" />
                        </Button.ToolTip>
                        <Button.ContextMenu>
                            <ContextMenu FontFamily="Segoe UI">
                                <MenuItem Header="Playback" FontFamily="Segoe UI">
                                    <MenuItem Header="Speed 1x" Tag="1" Click="PlaybackSpeedMenuItem_OnClick" FontFamily="Segoe UI" />
                                    <MenuItem Header="Speed 1.5x" Tag="1.5" Click="PlaybackSpeedMenuItem_OnClick" FontFamily="Segoe UI" />
                                    <MenuItem Header="Speed 2x" Tag="2" Click="PlaybackSpeedMenuItem_OnClick" FontFamily="Segoe UI" />
                                    <MenuItem Header="Speed 10x" Tag="10" Click="PlaybackSpeedMenuItem_OnClick" FontFamily="Segoe UI" />
                                    <Separator />
                                    <MenuItem Header="Custom..." Click="CustomPlaybackSpeedMenuItem_OnClick" FontFamily="Segoe UI" />
                                </MenuItem>
                                <MenuItem Header="Resolution" FontFamily="Segoe UI">
                                    <MenuItem Header="Follow Target" Tag="Follow" Click="ResolutionModeMenuItem_OnClick" FontFamily="Segoe UI" />
                                    <MenuItem Header="1080p (1920 x 1080)" Tag="1920x1080" Click="ResolutionModeMenuItem_OnClick" FontFamily="Segoe UI" />
                                    <MenuItem Header="2K (2560 x 1440)" Tag="2560x1440" Click="ResolutionModeMenuItem_OnClick" FontFamily="Segoe UI" />
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="TargetPickerButton"
                            Width="38"
                            Height="24"
                            Margin="12,0,0,0"
                            Click="TargetPickerButton_OnClick"
                            MouseRightButtonUp="TargetPickerButton_OnMouseRightButtonUp"
                            Style="{StaticResource TitleBarIconButtonStyle}">
                        <Grid Width="22" Height="16">
                            <Border x:Name="TargetComputerIcon"
                                    Width="15"
                                    Height="10"
                                    Margin="0,0,0,3"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    BorderThickness="1" />
                            <Border x:Name="TargetComputerBaseIcon"
                                    Width="7"
                                    Height="1"
                                    Margin="4,11,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock x:Name="TargetPlusIcon"
                                       Margin="14,-3,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       Text="+" />
                        </Grid>
                    </Button>
                    <TextBlock x:Name="TitleTargetStatusText"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Style="{StaticResource MutedTextStyle}"
                               Text="Target not attached" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Top"
                            Height="34"
                            Orientation="Horizontal">
                    <TextBlock x:Name="CurrentFileText"
                               Width="150"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               Style="{StaticResource MutedTextStyle}"
                               Text="No macro selected"
                               TextTrimming="CharacterEllipsis" />
                    <Border Width="1"
                            Height="18"
                            Margin="0,0,8,0"
                            Background="#3E8A8A8A" />
                    <Button x:Name="RecordButton"
                            Style="{StaticResource SmallActionButtonStyle}"
                            Click="RecordButton_OnClick"
                            ToolTip="Record">
                        <Grid>
                            <Ellipse x:Name="RecordIcon"
                                     Width="12"
                                     Height="12"
                                     Fill="#FF4B4B" />
                        </Grid>
                    </Button>
                    <Button x:Name="PlayButton"
                            Style="{StaticResource PrimaryPlayButtonStyle}"
                            Click="PlayButton_OnClick"
                            ToolTip="Play">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <Path x:Name="PlayIcon"
                                  Width="12"
                                  Height="14"
                                  Fill="Transparent"
                                  Stroke="#66E17B"
                                  StrokeThickness="2"
                                  StrokeLineJoin="Round"
                                  Stretch="Fill"
                                  Data="M 0 0 L 12 7 L 0 14 Z" />
                            <TextBlock Margin="7,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#F6F2FF"
                                       Text="Play" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="StopButton"
                            Style="{StaticResource SmallActionButtonStyle}"
                            Click="StopButton_OnClick"
                            ToolTip="Stop">
                        <Grid Width="14" Height="14">
                            <Rectangle x:Name="StopIcon"
                                       RadiusX="1"
                                       RadiusY="1"
                                       Fill="Transparent"
                                       Stroke="#CC3B3B"
                                       StrokeThickness="2" />
                            <Path Width="6"
                                  Height="6"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Top"
                                  Fill="#6F2020"
                                  Stretch="Fill"
                                  Data="M 0 0 L 6 0 L 6 6 Z" />
                        </Grid>
                    </Button>
                    <Border Width="1"
                            Height="18"
                            Margin="2,0,8,0"
                            Background="#3E8A8A8A" />
                    <Button x:Name="ClientLayoutFlyoutButton"
                            Style="{StaticResource TitleBarIconButtonStyle}"
                            Click="ClientLayoutFlyoutButton_OnClick"
                            Content="&#xE8A9;"
                            FontFamily="Segoe MDL2 Assets">
                        <Button.ToolTip>
                            <TextBlock FontFamily="Segoe UI" Text="Client layout" />
                        </Button.ToolTip>
                    </Button>
                    <Button x:Name="BlackoutOverlayButton"
                            Style="{StaticResource TitleBarIconButtonStyle}"
                            Click="BlackoutOverlayButton_OnClick"
                            Content="&#xE7F4;"
                            FontFamily="Segoe MDL2 Assets">
                        <Button.ToolTip>
                            <TextBlock FontFamily="Segoe UI" Text="Blackout overlay" />
                        </Button.ToolTip>
                    </Button>
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource TitleBarIconButtonStyle}"
                            Click="SettingsButton_OnClick"
                            Content="&#xE713;"
                            FontFamily="Segoe MDL2 Assets" />
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MinimizeButton_OnClick"
                            Content="&#xE921;" />
                    <Button x:Name="MaximizeButton"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MaximizeButton_OnClick"
                            Content="&#xE922;" />
                    <Button x:Name="CloseButton"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="CloseButton_OnClick"
                            Content="&#xE8BB;"
                            Foreground="#E5E5E5" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="10,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,10,12,10"
                        Background="Transparent"
                        BorderThickness="0">
                    <Grid Margin="8,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24" />
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="64" />
                            <RowDefinition Height="1" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <Button Style="{StaticResource RailModeTabActiveButtonStyle}"
                                    Content="Macros" />
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <TextBlock x:Name="LeftPanelTitleText"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="MACROS" />
                            <StackPanel x:Name="MacroHeaderActions"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                <Button Width="28"
                                        Height="24"
                                        Margin="0,0,5,0"
                                        Style="{StaticResource TinyFileButtonStyle}"
                                        Click="NewMacroButton_OnClick"
                                        Content="+" />
                                <Button Width="28"
                                        Height="24"
                                        Style="{StaticResource TinyFileButtonStyle}"
                                        Click="RefreshMacroTreeButton_OnClick"
                                        Content="&#x21BB;" />
                            </StackPanel>
                        </Grid>

                        <TreeView x:Name="MacroTreeView"
                                  Grid.Row="2"
                                  Margin="0,0,0,0"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="#F2F2F2"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  MouseDoubleClick="MacroTreeView_OnMouseDoubleClick"
                                  SelectedItemChanged="MacroTreeView_OnSelectedItemChanged" />

                        <Grid x:Name="MacroFileActionsGrid"
                                      Grid.Row="3"
                                      Margin="0,0,0,0"
                                      VerticalAlignment="Bottom">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="NewMacroButton"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="3"
                                    Style="{StaticResource TinyFileButtonStyle}"
                                    Click="NewMacroButton_OnClick"
                                    Content="New" />
                            <Button x:Name="SaveMacroButton"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,7,0,0"
                                    Style="{StaticResource TinyFileButtonStyle}"
                                    Click="SaveMacroButton_OnClick"
                                    Content="Save Macro" />
                            <Button x:Name="OpenMacroButton"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,7,0,0"
                                    Style="{StaticResource TinyFileButtonStyle}"
                                    Click="OpenMacroButton_OnClick"
                                    Content="Load Macro" />
                        </Grid>

                        <Border Grid.Row="4"
                                Height="1"
                                Margin="0,8,0,8"
                                Background="#30484848" />

                        <StackPanel Grid.Row="5"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <Button x:Name="AutoclickerRailTabButton"
                                    Style="{StaticResource RailModeTabActiveButtonStyle}"
                                    Click="AutoclickerRailTabButton_OnClick"
                                    Content="Autoclicker" />
                            <Button x:Name="AntiAfkRailTabButton"
                                    Style="{StaticResource RailModeTabButtonStyle}"
                                    Click="AntiAfkRailTabButton_OnClick"
                                    Content="Anti-AFK" />
                        </StackPanel>

                        <ScrollViewer x:Name="AutoclickerPanel"
                                      Grid.Row="6"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,2,4,0">
                                <TextBlock x:Name="AutoclickerStatusText"
                                           Margin="0,0,0,10"
                                           HorizontalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#F1F1F1"
                                           Text="status: idle" />

                                <Grid Margin="0,0,0,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="28" />
                                        <RowDefinition Height="28" />
                                        <RowDefinition Height="28" />
                                        <RowDefinition Height="28" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#F2F2F2"
                                               Text="# of clicks" />
                                    <TextBox x:Name="AutoclickerClickCountTextBox"
                                             Grid.Column="1"
                                             Style="{StaticResource CompactInputStyle}"
                                             IsReadOnly="True"
                                             Text="0" />
                                    <TextBlock Grid.Row="1"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#F2F2F2"
                                               Text="clicks/s" />
                                    <TextBox x:Name="AutoclickerClicksPerSecondTextBox"
                                             Grid.Row="1"
                                             Grid.Column="1"
                                             Style="{StaticResource CompactInputStyle}"
                                             Text="2" />
                                    <TextBlock Grid.Row="2"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#F2F2F2"
                                               Text="hotkey" />
                                    <Button x:Name="AutoclickerHotkeyButton"
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            Style="{StaticResource TinyFileButtonStyle}"
                                            Click="AutoclickerHotkeyButton_OnClick"
                                            Content="F8" />
                                    <TextBlock Grid.Row="3"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#F2F2F2"
                                               Text="stop at" />
                                    <TextBox x:Name="AutoclickerStopAtTextBox"
                                             Grid.Row="3"
                                             Grid.Column="1"
                                             Style="{StaticResource CompactInputStyle}"
                                             GotKeyboardFocus="AutoclickerStopAtTextBox_OnGotKeyboardFocus"
                                             LostKeyboardFocus="AutoclickerStopAtTextBox_OnLostKeyboardFocus"
                                             Text="never" />
                                </Grid>

                                <Button x:Name="AutoclickerStopButton"
                                        Height="46"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource TinyFileButtonStyle}"
                                        Click="StopAutoclickerButton_OnClick"
                                        Content="STOP" />

                                <Border Style="{StaticResource AutoclickerGroupStyle}">
                                    <StackPanel>
                                        <TextBlock Margin="8,-17,0,4"
                                                   Padding="4,0"
                                                   HorizontalAlignment="Left"
                                                   Background="{StaticResource SurfaceBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#F2F2F2"
                                                   Text="press / toggle" />
                                        <RadioButton x:Name="AutoclickerPressRadioButton"
                                                     GroupName="AutoclickerMode"
                                                     Style="{StaticResource AutoclickerRadioStyle}"
                                                     Content="press" />
                                        <RadioButton x:Name="AutoclickerToggleRadioButton"
                                                     GroupName="AutoclickerMode"
                                                     IsChecked="True"
                                                     Style="{StaticResource AutoclickerRadioStyle}"
                                                     Content="toggle" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource AutoclickerGroupStyle}">
                                    <StackPanel>
                                        <TextBlock Margin="8,-17,0,4"
                                                   Padding="4,0"
                                                   HorizontalAlignment="Left"
                                                   Background="{StaticResource SurfaceBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#F2F2F2"
                                                   Text="mouse to click" />
                                        <RadioButton x:Name="AutoclickerLeftRadioButton"
                                                     GroupName="AutoclickerClickTarget"
                                                     IsChecked="True"
                                                     Style="{StaticResource AutoclickerRadioStyle}"
                                                     Content="left" />
                                        <RadioButton x:Name="AutoclickerMiddleRadioButton"
                                                     GroupName="AutoclickerClickTarget"
                                                     Style="{StaticResource AutoclickerRadioStyle}"
                                                     Content="middle" />
                                        <RadioButton x:Name="AutoclickerRightRadioButton"
                                                     GroupName="AutoclickerClickTarget"
                                                     Style="{StaticResource AutoclickerRadioStyle}"
                                                     Content="right" />
                                    </StackPanel>
                                </Border>

                                <Expander Header="Advanced"
                                          Style="{StaticResource AutoclickerAdvancedExpanderStyle}">
                                    <StackPanel>
                                        <CheckBox x:Name="AutoclickerTargetOnlyCheckBox"
                                                  Margin="0,0,0,8"
                                                  Foreground="#E6E6E6"
                                                  IsChecked="True"
                                                  Content="Target area only" />
                                        <CheckBox x:Name="AutoclickerBroadcastCheckBox"
                                                  Foreground="#E6E6E6"
                                                  Content="Broadcast relative spot" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                        <ScrollViewer x:Name="AntiAfkPanel"
                                      Grid.Row="6"
                                      Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,2,4,0">
                                <TextBlock x:Name="AntiAfkStatusText"
                                           Margin="0,0,0,10"
                                           HorizontalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#F1F1F1"
                                           Text="status: idle" />
                                <Border Style="{StaticResource AutoclickerGroupStyle}">
                                    <StackPanel>
                                        <TextBlock Margin="8,-17,0,8"
                                                   Padding="4,0"
                                                   HorizontalAlignment="Left"
                                                   Background="{StaticResource SurfaceBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#F2F2F2"
                                                   Text="cycle" />
                                        <TextBlock Margin="0,0,0,8"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="Uses the autoclicker broadcast path at the current relative client spot across attached processes." />
                                        <TextBlock FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="Rate: 0.002 clicks/s (~8m 20s)" />
                                    </StackPanel>
                                </Border>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#F2F2F2"
                                               Text="hotkey" />
                                    <Button x:Name="AntiAfkHotkeyButton"
                                            Grid.Column="1"
                                            Style="{StaticResource TinyFileButtonStyle}"
                                            Click="AntiAfkHotkeyButton_OnClick"
                                            Content="F7" />
                                </Grid>
                                <Button x:Name="AntiAfkToggleButton"
                                        Height="46"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource TinyFileButtonStyle}"
                                        Click="AntiAfkToggleButton_OnClick"
                                        Content="ENABLE" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="5"
                              Margin="-6,10,7,10"
                              HorizontalAlignment="Stretch"
                              Background="#203F3F3F" />

                <Grid Grid.Column="2"
                      Margin="0,10,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="WorkspaceTabsRow" Height="30" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border x:Name="WorkspaceTabsChrome"
                            Grid.Row="0"
                            Background="#3A151515"
                            BorderBrush="#263F3F3F"
                            BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="True"
                                   Margin="0,0,0,-3">
                            <Button Width="28"
                                    Height="24"
                                    Margin="6,2,0,2"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource TinyFileButtonStyle}"
                                    Click="NewEditorTabButton_OnClick"
                                    Content="+" />
                            <ScrollViewer x:Name="WorkspaceTabsScrollViewer"
                                          DockPanel.Dock="Left"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          PreviewMouseWheel="WorkspaceTabsScrollViewer_OnPreviewMouseWheel">
                                <StackPanel x:Name="WorkspaceTabsPanel"
                                            Orientation="Horizontal">
                                    <Button x:Name="TargetWorkspaceTabButton"
                                            Style="{StaticResource WorkspaceTabActiveButtonStyle}"
                                            Click="TargetWorkspaceTabButton_OnClick"
                                            Content="Game" />
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Grid x:Name="WorkspaceSurfaceGrid"
                          Grid.Row="1"
                          Margin="0,-1,0,0">
                        <Grid x:Name="TargetViewport">
                            <Grid x:Name="CenterAcrylicSurface" Visibility="Hidden">
                                <Border CornerRadius="10"
                                        Background="#70444444"
                                        BorderBrush="#2FFFFFFF"
                                        BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="18" Opacity="0.16" ShadowDepth="0" Color="#000000" />
                                    </Border.Effect>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid x:Name="MacroEditorHost"
                              Visibility="Collapsed"
                              Background="#FF101010">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="#FF151515"
                                    BorderBrush="#263F3F3F"
                                    BorderThickness="0,0,1,0">
                                <TextBlock Margin="0,10,0,0"
                                           HorizontalAlignment="Center"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Foreground="#666666"
                                           Text="1" />
                            </Border>
                            <TextBox x:Name="MacroEditorTextBox"
                                     Grid.Column="1"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     Background="#FF101010"
                                     BorderThickness="0"
                                     CaretBrush="#F2F2F2"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     Foreground="#E6E6E6"
                                     HorizontalScrollBarVisibility="Visible"
                                     Padding="14,10"
                                     TextChanged="MacroEditorTextBox_OnTextChanged"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Visible" />
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    BorderBrush="#37474747"
                    BorderThickness="0,1,0,0"
                    Background="{StaticResource SurfaceAltBrush}"
                    CornerRadius="0,0,10,10">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="210" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource GreenAccentBrush}" />
                        <TextBlock x:Name="StatusText" Margin="7,0,0,0" Style="{StaticResource MutedTextStyle}" Text="Status: Ready" />
                    </StackPanel>
                    <TextBlock x:Name="CursorText" Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}" Text="CORD: (--, --)" />
                    <TextBlock x:Name="PlaybackSpeedText" Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}" Text="Speed: 1x" />
                    <TextBlock x:Name="ClockText" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Right" Style="{StaticResource MutedTextStyle}" Text="12:00:00 AM" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</ui:FluentWindow>
