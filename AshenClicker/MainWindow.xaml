<Window x:Class="AshenClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Ashen Clicker"
        Width="230"
        Height="410"
        MinWidth="230"
        MinHeight="410"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#141414"
        Icon="Assets/Icons/Ashen Tasker Icon.ico">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F0141414" />
        <SolidColorBrush x:Key="PanelBrush" Color="#B82A2A2A" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#B8D0D0D0" />
        <SolidColorBrush x:Key="ButtonBrush" Color="#B0252525" />

        <Style x:Key="CompactInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Background" Value="#E7131313" />
            <Setter Property="BorderBrush" Value="#334F4F4F" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="AshButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Background" Value="{StaticResource ButtonBrush}" />
            <Setter Property="BorderBrush" Value="#3F5F5F5F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#70313131" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GroupStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0,6,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#324F4F4F" />
            <Setter Property="BorderThickness" Value="1,1,0,0" />
        </Style>

        <Style x:Key="RadioStyle" TargetType="RadioButton">
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="#EDEDED" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid MinHeight="{TemplateBinding MinHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="OuterDot"
                                    Width="13"
                                    Height="13"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    CornerRadius="7"
                                    Background="#1D1D1D"
                                    BorderBrush="#A8D0D0D0"
                                    BorderThickness="1.5">
                                <Border x:Name="InnerDot"
                                        Width="5"
                                        Height="5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        CornerRadius="3"
                                        Background="#F2F2F2"
                                        Opacity="0" />
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterDot" Property="BorderBrush" Value="#E7F2F2F2" />
                                <Setter TargetName="OuterDot" Property="Background" Value="#282828" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OuterDot" Property="BorderBrush" Value="#F2F2F2" />
                                <Setter TargetName="OuterDot" Property="Background" Value="#353535" />
                                <Setter TargetName="InnerDot" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button" BasedOn="{StaticResource AshButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  IsHitTestVisible="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb MinHeight="28"
                                           Background="#706F6F6F">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="4"
                                                        HorizontalAlignment="Right"
                                                        CornerRadius="2"
                                                        Background="{TemplateBinding Background}" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  IsHitTestVisible="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="1"
            CornerRadius="8"
            Background="#F0171717"
            BorderBrush="#3F5F5F5F"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="*" />
                <RowDefinition Height="20" />
            </Grid.RowDefinitions>

            <Grid Background="#5A111111"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="4,-2,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBlock Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#F3F3F3"
                               Text="Ashen Clicker" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="SettingsButton_OnClick"
                            Content="&#xE713;" />
                    <Border Width="1"
                            Height="17"
                            Margin="1,8"
                            Background="#3E8A8A8A" />
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="MinimizeButton_OnClick"
                            Content="&#xE921;" />
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="CloseButton_OnClick"
                            Content="&#xE8BB;" />
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12,5,10,3">
                    <Grid Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="29" />
                            <RowDefinition Height="29" />
                            <RowDefinition Height="29" />
                            <RowDefinition Height="29" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="78" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#F2F2F2" Text="# of clicks" />
                        <TextBox x:Name="ClickCountTextBox" Grid.Column="1" Style="{StaticResource CompactInputStyle}" IsReadOnly="True" Text="10" />

                        <TextBlock Grid.Row="1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#F2F2F2" Text="clicks/s" />
                        <TextBox x:Name="ClicksPerSecondTextBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource CompactInputStyle}" Text="2" />

                        <TextBlock Grid.Row="2" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#F2F2F2" Text="hotkey" />
                        <Button x:Name="HotkeyButton" Grid.Row="2" Grid.Column="1" Style="{StaticResource AshButtonStyle}" Click="HotkeyButton_OnClick" Content="F8" />

                        <TextBlock Grid.Row="3" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#F2F2F2" Text="stop at" />
                        <TextBox x:Name="StopAtTextBox" Grid.Row="3" Grid.Column="1" Style="{StaticResource CompactInputStyle}" Text="never" GotKeyboardFocus="StopAtTextBox_OnGotKeyboardFocus" LostKeyboardFocus="StopAtTextBox_OnLostKeyboardFocus" />
                    </Grid>

                    <Button x:Name="StopButton"
                            Height="38"
                            Margin="0,0,0,8"
                            Style="{StaticResource AshButtonStyle}"
                            Click="StopButton_OnClick"
                            Content="STOP" />

                    <Border Style="{StaticResource GroupStyle}">
                        <StackPanel>
                            <TextBlock Margin="8,-10,0,6" Padding="4,0" HorizontalAlignment="Left" Background="#F0171717" FontWeight="SemiBold" Foreground="#F2F2F2" Text="press / toggle" />
                            <StackPanel Margin="8,0,0,0">
                                <RadioButton x:Name="PressRadioButton" GroupName="Mode" Style="{StaticResource RadioStyle}" Content="press" />
                                <RadioButton x:Name="ToggleRadioButton" GroupName="Mode" IsChecked="True" Style="{StaticResource RadioStyle}" Content="toggle" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GroupStyle}">
                        <StackPanel>
                            <TextBlock Margin="8,-5,0,6" Padding="4,0" HorizontalAlignment="Left" Background="#F0171717" FontWeight="SemiBold" Foreground="#F2F2F2" Text="thing to click" />
                            <StackPanel Margin="8,0,0,0">
                                <RadioButton x:Name="LeftRadioButton" GroupName="Button" IsChecked="True" Style="{StaticResource RadioStyle}" Content="left" />
                                <RadioButton x:Name="MiddleRadioButton" GroupName="Button" Style="{StaticResource RadioStyle}" Content="middle" />
                                <RadioButton x:Name="RightRadioButton" GroupName="Button" Style="{StaticResource RadioStyle}" Content="right" />
                                <StackPanel Margin="0,2,0,0"
                                            Orientation="Horizontal">
                                    <RadioButton x:Name="KeyTargetRadioButton"
                                                 GroupName="Button"
                                                 VerticalAlignment="Center"
                                                 Style="{StaticResource RadioStyle}"
                                                 Content="key" />
                                    <Button x:Name="TargetKeyButton"
                                            Width="78"
                                            Height="24"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource AshButtonStyle}"
                                            Click="TargetKeyButton_OnClick"
                                            Content="Space" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Background="#68111111"
                    BorderBrush="#245F5F5F"
                    BorderThickness="0,1,0,0">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot"
                                 Width="7"
                                 Height="7"
                                 Margin="0,0,5,0"
                                 Fill="#9A9A3A3A" />
                        <TextBlock x:Name="StatusText"
                                   VerticalAlignment="Center"
                                   FontSize="10"
                                   Foreground="#D8D8D8"
                                   Text="Status: idle" />
                    </StackPanel>

                    <TextBlock x:Name="VersionText"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               FontSize="10"
                               Foreground="#AFC8C8C8"
                               Text="v0.1 ALPHA" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
